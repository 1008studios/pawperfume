# ═════════════════════════════════════════════════
# PawPerfume — Environment Variables
# ═════════════════════════════════════════════════

# ── Neon Database ───────────────────────────────
# Use the non-pooled connection string for serverless
POSTGRES_URL_NON_POOLING=
DATABASE_URL_UNPOOLED=
DATABASE_URL=

# ── SAAS Master Admin ──────────────────────────
# IMPORTANT: Use a strong password (16+ chars, mixed case, numbers, symbols)
# This is used for admin panel authentication
ADMIN_PASSWORD=

# ── Facebook / Meta (REQUIRED for webhook) ─────
FB_PAGE_ACCESS_TOKEN=
# CRITICAL: FB_APP_SECRET is required for webhook signature validation!
# Without this, attackers can send fake webhook events
FB_APP_SECRET=
# FB_VERIFY_TOKEN is used during webhook setup in Facebook Developer Console
FB_VERIFY_TOKEN=replace-with-random-secret
FB_PAGE_ID=

# ── Vercel ─────────────────────────────────────
APP_PUBLIC_URL=
CRON_SECRET=

# ── Vercel Blob ────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── AI Providers (Optional) ────────────────────
# At least one AI provider is recommended for chatbot functionality
OPENROUTER_API_KEY=    # Recommended: supports multiple models
DEEPSEEK_API_KEY=      # Alternative: good for code tasks
GEMINI_API_KEY=        # Alternative: good for general chat + vision
OPENAI_API_KEY=        # Alternative: GPT models

# ── Upstash KV (Optional) ─────────────────────
# Recommended for rate limiting in production
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Google Workspace (Optional, for email/sheets) ──
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REFRESH_TOKEN=
