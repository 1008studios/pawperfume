# ═════════════════════════════════════════════════
# Messenger SAAS — Environment Variables
# ═════════════════════════════════════════════════

# ── Neon Database ───────────────────────────────
DATABASE_URL=

# ── SAAS Master Admin ──────────────────────────
ADMIN_PASSWORD=

# ── Default Facebook / Meta (fallback if tenant not configured) ──
FB_PAGE_ACCESS_TOKEN=
FB_APP_SECRET=
FB_VERIFY_TOKEN=replace-with-random-secret
FB_PAGE_ID=

# ── Vercel ─────────────────────────────────────
APP_PUBLIC_URL=
CRON_SECRET=

# ── Vercel Blob ────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── AI Providers (Optional) ────────────────────
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Upstash KV (Optional) ─────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Google Workspace (Optional, for email/sheets) ──
GOOGLE_WORKSPACE_CLIENT_ID=
GOOGLE_WORKSPACE_CLIENT_SECRET=
GOOGLE_WORKSPACE_REFRESH_TOKEN=
